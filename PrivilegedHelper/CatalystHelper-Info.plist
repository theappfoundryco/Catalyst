<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>com.shivanggulati.catalyst.helper</string>
    <key>CFBundleName</key>
    <string>CatalystHelper</string>
    <key>CFBundleVersion</key>
    <string>1.0.0</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>

    <!-- Only the genuine Catalyst app, signed by your team, may talk to the
         helper. Replace 6957JGQD3R if your Team ID ever changes. -->
    <key>SMAuthorizedClients</key>
    <array>
        <string>identifier "com.shivanggulati.catalyst" and anchor apple generic and certificate leaf[subject.OU] = "6957JGQD3R"</string>
    </array>
</dict>
</plist>
